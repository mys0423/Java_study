package variableTask;

public class FormatTask01 {
	public static void main(String[] args) {
//      식을 완성시키시오. (포멧으로 출력하기)
//      10 + 20 = 30
//      7 * 8 = 56
//      6 * 4 = 24
		
		int a = 0;
		int b = 0;
		
		a = 10;
		b = 20; 
		System.out.printf("%d + %d = %d", a, b, a + b);

		a = 7;
		b = 8; 
		System.out.printf("%d * %d = %d", a, b, a * b);
		
		a = 6;
		b = 4; 
		System.out.printf("%d + %d = %d", a, b, a * b);
		
		
	}
}
